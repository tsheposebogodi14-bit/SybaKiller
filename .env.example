# SybaKiller — live production defaults (copy to .env)

SYBA_ENV=production
SYBA_LOG_LEVEL=INFO
SYBA_API_HOST=127.0.0.1
SYBA_API_PORT=8000

# Live market data (Binance public WebSocket — no API key required)
MARKET_DATA_PROVIDER=binance
MARKET_DATA_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
BINANCE_TESTNET=false

# Live execution (required for POST /orders — use testnet first)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Push ticks to Redis subscribers (optional)
SYBA_TENANT_ID=default

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_TICKS_ENABLED=true

# Crash recovery — resume open orders after restart
STATE_SNAPSHOT_ENABLED=true
STATE_SNAPSHOT_INTERVAL_SEC=30

DATABASE_URL=postgresql+asyncpg://syba:syba@127.0.0.1:5432/sybakiller

SYBA_MAX_ORDER_NOTIONAL=100000
SYBA_MAX_POSITION_NOTIONAL=500000
SYBA_MAX_ORDERS_PER_SECOND=50

# Tests only: SYBA_ENV=test MARKET_DATA_PROVIDER=simulated
